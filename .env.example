# MoodBook — Firebase Configuration
# 1. Go to https://console.firebase.google.com
# 2. Create a new project (or use an existing one)
# 3. Click "Add app" → Web app
# 4. Enable "Realtime Database" in Build → Realtime Database → Create database
#    Choose any region. Start in TEST MODE (you can secure it later)
# 5. Copy the config values below from Project Settings → Your apps → SDK setup

VITE_FIREBASE_API_KEY=YOUR_API_KEY_HERE
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://YOUR_PROJECT_ID-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID_HERE
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID_HERE
VITE_FIREBASE_APP_ID=YOUR_APP_ID_HERE
